# Cursor CLI auth — create at cursor.com → Settings → API Keys
CURSOR_API_KEY=key_xxxxxxxxxxxxxxxx

# Model passed to `agent --model`. `auto` lets Cursor pick; run
# `agent --list-models` for what your account can use.
LOOP_MODEL=auto

# Path to the exported tickets file the MockTicketStore reads.
LOOP_TICKETS_FILE=data/tickets.sample.json

# Editor used by the plan gate's [e]dit action (falls back to notepad on
# Windows, vi elsewhere, when unset).
# EDITOR=code --wait
